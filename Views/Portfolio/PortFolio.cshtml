    <script>
        $(document).ready(function () {

            $('#contactForm').on('submit', function (e) {
                e.preventDefault();

                document.getElementById("Save").disabled = true;

                // Enable the button after 5 seconds (optional example)
                setTimeout(function () {
                    document.getElementById("Save").disabled = false;
                }, 5000);

                const systemRegistration = {
                    systemId: `${navigator.platform}_${navigator.userAgent}`,
                    // configurationDetails: `OS: ${navigator.platform}, Browser: ${navigator.userAgent}, Screen: ${window.screen.width}x${window.screen.height}`,
                    configurationDetails: `OS: ${navigator.platform}, Browser: ${navigator.userAgent}`,
                    registeredAt: new Date().toISOString()
                };

                const formData = {
                    name: $('input[name="name"]').val(),
                    email: $('input[name="email"]').val(),
                    body: $('textarea[name="body"]').val(),
                    systemRegistration: systemRegistration
                };

                $.ajax({
                    url: '/Registration/Registration',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(formData),
                    success: function (response) {
                        alert(response);
                    },
                    error: function (xhr) {
                        alert(`Error: ${xhr.responseText}`);
                    }
                });
            });

        })
    </script>

    <!-- Realistic Galaxy Animation Script -->
    <script>
        const canvas = document.getElementById('galaxyCanvas');
        const ctx = canvas.getContext('2d');
        let width, height;
        let particles = [];

        function initGalaxy() {
            width = canvas.width = window.innerWidth;
            height = canvas.height = window.innerHeight;
            particles = [];
            
            const arms = 2; // Realistic 2 spiral arms
            const maxRadius = Math.max(width, height) * 0.9;
            
            // Core and disk particles
            for (let i = 0; i < 3000; i++) {
                // Focus heavily on the center using exponential distribution approximation
                let d = (Math.random() + Math.random() + Math.random()) / 3;
                d = Math.pow(d, 2.5);
                const radius = d * maxRadius;
                
                let angle = d * Math.PI * 6; // Spiral winding
                const armOffset = (i % arms) * Math.PI; 
                angle += armOffset;
                
                // Add natural scattering which increases further from center
                let scatter = (Math.random() - 0.5) * Math.PI * (0.8 + d * 2);
                
                // 30% are disk population, not tied to arms
                if (Math.random() < 0.3) {
                    scatter = Math.random() * Math.PI * 2; 
                }
                angle += scatter;
                
                // Assign realistic star colors (bluish-white arms, yellow-white core)
                let color, size;
                if (d < 0.1) { // Bulge/Core (Yellow/White)
                    color = `rgba(255, ${220 + Math.random()*35}, ${180 + Math.random()*75}, `;
                    size = Math.random() * 1.5;
                } else if (Math.random() < 0.15) { // H II regions / dust lanes
                    color = `rgba(255, 150, 200, `; // pinkish
                    size = Math.random() * 1.5;
                } else { // Disk / Arms (Blue/White)
                    color = `rgba(${180 + Math.random()*75}, ${220 + Math.random()*35}, 255, `;
                    size = Math.random() * 1.2;
                }
                
                // Opacity falls off at edges
                const opacity = Math.min(0.9, Math.max(0.1, 1 - d));

                particles.push({
                    angle: angle,
                    radius: radius,
                    colorBase: color,
                    baseOpacity: opacity,
                    speed: 0.0003 + (1 - d) * 0.0002, // inner rotates slightly faster
                    size: size,
                    isStatic: false
                });
            }

            // Scatter background stars
            for (let i = 0; i < 400; i++) {
                particles.push({
                    x: Math.random() * width,
                    y: Math.random() * height,
                    size: Math.random() * 1.5,
                    color: `rgba(255, 255, 255, `,
                    baseOpacity: Math.random(),
                    isStatic: true,
                    phase: Math.random() * Math.PI * 2
                });
            }
        }

        function drawGalaxy() {
            // Deep cosmic background
            let bg = ctx.createRadialGradient(width/2, height/2, 0, width/2, height/2, Math.max(width, height));
            bg.addColorStop(0, '#050a14');
            bg.addColorStop(0.5, '#020408');
            bg.addColorStop(1, '#000000');
            ctx.fillStyle = bg;
            ctx.fillRect(0, 0, width, height);

            ctx.globalCompositeOperation = 'screen'; // Great for blending lights
            
            // Glow of the galactic core
            let coreGrp = ctx.createRadialGradient(width/2, height/2, 0, width/2, height/2, Math.min(width, height) * 0.35);
            coreGrp.addColorStop(0, 'rgba(255, 240, 210, 0.15)'); // Warm glow
            coreGrp.addColorStop(0.4, 'rgba(80, 130, 255, 0.05)'); // Cool halo
            coreGrp.addColorStop(1, 'rgba(0, 0, 0, 0)');
            ctx.fillStyle = coreGrp;
            ctx.fillRect(0, 0, width, height);

            const centerX = width / 2;
            const centerY = height / 2;
            const time = Date.now() * 0.001;

            for (let i = 0; i < particles.length; i++) {
                let p = particles[i];
                
                if (p.isStatic) {
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
                    // Twinkle effect
                    const currentOpacity = Math.max(0.1, p.baseOpacity + Math.sin(time * 2 + p.phase) * 0.3);
                    ctx.fillStyle = p.color + currentOpacity + ')';
                    ctx.fill();
                } else {
                    p.angle -= p.speed;
                    
                    const x = centerX + Math.cos(p.angle) * p.radius;
                    // Squish by 0.35 to give realistic 3D perspective tilt
                    const y = centerY + Math.sin(p.angle) * p.radius * 0.35; 
                    
                    ctx.beginPath();
                    ctx.arc(x, y, p.size, 0, Math.PI * 2);
                    ctx.fillStyle = p.colorBase + p.baseOpacity + ')';
                    ctx.fill();
                }
            }
            
            ctx.globalCompositeOperation = 'source-over';
            requestAnimationFrame(drawGalaxy);
        }

        window.addEventListener('resize', initGalaxy);
        initGalaxy();
        drawGalaxy();
    </script>

</body>
</html>
